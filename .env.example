POSTGRES_DB=lang_war
POSTGRES_USER=lang_war
POSTGRES_PASSWORD=lang_war_password
POSTGRES_PORT=5432

DATABASE_URL=postgres://lang_war:lang_war_password@localhost:5432/lang_war?sslmode=disable
GITHUB_TOKEN_ENCRYPTION_SECRET=development-only-github-token-secret

# GCP / デプロイ設定
# setup-wif.sh と setup-secrets.sh が ~/.env から読み込む変数。
GCP_PROJECT_ID=your-gcp-project-id
GITHUB_REPO=jyogi-web/DDD_A-to-Z

NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# SESSION_SECRET は空のままにすると setup-secrets.sh が自動生成する
SESSION_SECRET=
