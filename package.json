{
  "name": "lang-war",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:status": "docker compose ps postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "atlas": "nix develop -c ./scripts/atlas.sh",
    "db:schema:inspect": "nix develop -c ./scripts/atlas.sh schema inspect --env local",
    "db:schema:validate": "nix develop -c ./scripts/atlas.sh schema inspect --env local --url env://src --format '{{ sql . }}' > /dev/null",
    "db:migrate:diff": "nix develop -c ./scripts/atlas.sh migrate diff --env local",
    "db:migrate:hash": "nix develop -c ./scripts/atlas.sh migrate hash --env local",
    "db:migrate:validate": "nix develop -c ./scripts/atlas.sh migrate validate --env local",
    "db:migrate:lint": "nix develop -c ./scripts/atlas.sh migrate lint --env local --latest 1",
    "db:migrate:status": "nix develop -c ./scripts/atlas.sh migrate status --env local",
    "db:migrate:dry-run": "nix develop -c ./scripts/atlas.sh migrate apply --env local --dry-run",
    "db:migrate:apply": "nix develop -c ./scripts/atlas.sh migrate apply --env local",
    "build": "turbo run build",
    "react-doctor": "turbo run react-doctor",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "turbo": "^2.9.12"
  }
}
